# Postgres credentials — same DB container as everything else.
# These users / DBs are already provisioned by vpn-monitor and traffic-monitor.

VPN_PG_USER=vpn_mon
VPN_PG_PASSWORD=
VPN_PG_DB=vpn_monitor

UMAMI_PG_USER=umami
UMAMI_PG_PASSWORD=
UMAMI_PG_DB=umami

# Public host used for HTTPS probes and TLS-cert expiry check.
PUBLIC_HOST=ai-native.japaneast.cloudapp.azure.com
