# Mounted-into-container paths. Defaults work with the docker-compose mounts.
DIGEST_DIR=/data/ai-feed/digest
GOACCESS_REPORT=/data/goaccess/index.html
HEARTBEAT_DIR=/data/heartbeats

# Public host — used for TLS-cert and HTTP probes.
PUBLIC_HOST=ai-native.japaneast.cloudapp.azure.com

# Postgres (umami container, reused for all DB queries — vpn_monitor and umami both live here)
PG_HOST=db
PG_PORT=5432
VPN_PG_USER=vpn_mon
VPN_PG_PASSWORD=
VPN_PG_DB=vpn_monitor
UMAMI_PG_USER=umami
UMAMI_PG_PASSWORD=
UMAMI_PG_DB=umami
